# ── LLM Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── LiteLLM Proxy ───────────────────────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-bc-master-key-change-me

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bcagent:bcagent@localhost:5432/bcagentic

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── GitLab (optional) ────────────────────────────────────────────────────────
GITLAB_TOKEN=glpat-...
GITLAB_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=your-gitlab-secret

# ── Linear (optional) ────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...

# ── HashiCorp Vault (optional) ───────────────────────────────────────────────
VAULT_ADDR=https://vault.bc.internal
VAULT_TOKEN=hvs.your-token

# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-32-char-random-string
API_BEARER_TOKEN=change-me-bearer-token
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Sandbox ──────────────────────────────────────────────────────────────────
SANDBOX_IMAGE=bc-agent-sandbox:latest
SANDBOX_MEMORY_LIMIT=2g
WORKSPACE_BASE=/tmp/bc-agent-workspaces
SANDBOX_BACKEND=docker
MICROVM_RUNTIME=docker-sbx

# ── Model Defaults ───────────────────────────────────────────────────────────
DEFAULT_MODEL=claude-sonnet
TASK_BUDGET_USD=5.0

# ── LangGraph ────────────────────────────────────────────────────────────────
LANGGRAPH_CHECKPOINTER_URL=postgresql://bcagent:bcagent@localhost:5432/bcagentic

# ── Plan Mode ────────────────────────────────────────────────────────────────
PLAN_MODE_ENABLED=true

# ── Coder Session Handoff ────────────────────────────────────────────────────
CODER_TOKEN_LIMIT=80000
CODER_MAX_SESSIONS=5

# ── Langfuse Observability ───────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SECRET_KEY=sk-lf-changeme
LANGFUSE_ENABLED=false
LANGFUSE_NEXTAUTH_SECRET=change-me-langfuse-secret
LANGFUSE_SALT=change-me-langfuse-salt
